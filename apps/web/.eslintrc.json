{
  "extends": ["../../.eslintrc.json"],
  "rules": {
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": true,
        "packageDir": ["./", "../../"]
      }
    ],
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": [
      "error",
      { "args": "all", "argsIgnorePattern": "^_|^newDate$", "varsIgnorePattern": "^_" }
    ]
  }
}
