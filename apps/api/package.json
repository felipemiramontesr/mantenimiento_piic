{
  "name": "@mantenimiento/api",
  "version": "1.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "test": "vitest run --coverage",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@fastify/cors": "^8.3.0",
    "@fastify/jwt": "^7.2.0",
    "@fastify/rate-limit": "^8.0.0",
    "fastify": "^4.21.0",
    "mysql2": "^3.6.0",
    "zod": "^3.22.0",
    "argon2": "^0.31.0",
    "dotenv": "^16.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.1.0",
    "vitest": "^0.34.0",
    "@vitest/coverage-istanbul": "^0.34.0"
  }
}
