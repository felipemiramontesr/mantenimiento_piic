{
  "name": "mantenimiento-piic",
  "version": "78.100.214",
  "engines": {
    "node": ">=24.0.0"
  },
  "description": "Automotive Maintenance Management System - PIIC Premium",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "npm run build --workspace=@mantenimiento/api",
    "start": "npm run build --workspace=@mantenimiento/api && node apps/api/dist/index.js",
    "test": "bun run --filter '*' test",
    "test:e2e": "bunx playwright test",
    "test:e2e:local": "bunx playwright test --config=playwright.local.config.ts",
    "test:e2e:ui": "bunx playwright test --ui",
    "lint": "bun run --filter '*' lint",
    "db:validate": "bun packages/database/scripts/validate-sql.ts",
    "protocol:verify": "bun scripts/verifyProtocolL.ts",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.38.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "eslint-plugin-security": "^2.1.1",
    "eslint-plugin-sonarjs": "^0.25.1",
    "eslint-plugin-unicorn": "^51.0.1",
    "husky": "^8.0.0",
    "lint-staged": "^13.0.0",
    "msw": "^2.13.4",
    "prettier": "^2.8.0",
    "tsx": "^4.19.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0"
  },
  "overrides": {
    "yaml": "^2.9.0",
    "micromatch": "^4.0.8"
  }
}
